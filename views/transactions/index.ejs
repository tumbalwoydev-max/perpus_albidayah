<%- include('../partials/header') %>

<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">Sirkulasi Perpustakaan</h1>
        <p class="text-sm text-gray-500 mt-1">Kelola peminjaman dan pengembalian buku siswa.</p>
    </div>
    <a href="/transactions/scan" class="inline-flex items-center justify-center py-2.5 px-4 rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 shadow-sm transition gap-2 font-medium">
        <i data-lucide="scan-line" class="w-5 h-5"></i> Scan QR Peminjaman
    </a>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">No Resi</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Peminjam</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Buku</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tgl Pinjam</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Batas Kembali</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Aksi</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                <% if(transactions.length > 0) { %>
                    <% transactions.forEach((txn) => { %>
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">TRX-<%= txn.id %></td>
                            <td class="px-6 py-4 text-sm font-medium text-emerald-700"><%= txn.Student.name %> <br><span class="text-xs text-gray-400 font-normal">NISN: <%= txn.Student.nisn %></span></td>
                            <td class="px-6 py-4 text-sm text-gray-900 border-b border-gray-100"><%= txn.Book.title %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= txn.borrow_date %></td>
                            
                            <% 
                                let isOverdue = false;
                                if(!txn.return_date) {
                                    const today = new Date().toISOString().split('T')[0];
                                    if(today > txn.expected_return_date) {
                                        isOverdue = true;
                                    }
                                }
                            %>
                            
                            <td class="px-6 py-4 whitespace-nowrap text-sm <%= isOverdue ? 'text-red-600 font-medium' : 'text-gray-500' %>">
                                <%= txn.expected_return_date %>
                            </td>
                            
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <% if(txn.return_date) { %>
                                    <span class="px-2.5 py-0.5 rounded-full bg-blue-50 text-blue-700 border border-blue-200 text-xs font-medium">
                                        Dikembalikan (<%= txn.return_date %>)
                                    </span>
                                <% } else { %>
                                    <span class="px-2.5 py-0.5 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200 text-xs font-medium">
                                        Sedang Dipinjam
                                    </span>
                                    <% if(isOverdue) { %>
                                        <br>
                                        <span class="text-xs text-red-500 mt-1 inline-block"><i data-lucide="alert-triangle" class="w-3 h-3 inline"></i> Terlambat!</span>
                                    <% } %>
                                <% } %>
                            </td>
                            
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium flex justify-end gap-2">
                                <a href="/transactions/receipt/<%= txn.id %>" class="text-gray-600 hover:text-gray-900 bg-gray-100 p-1.5 rounded-md transition" title="Cetak Struk">
                                    <i data-lucide="printer" class="w-4 h-4"></i>
                                </a>
                                <% if(!txn.return_date) { %>
                                    <a href="/transactions/return/<%= txn.id %>" class="text-emerald-600 hover:text-emerald-900 bg-emerald-50 px-3 py-1.5 rounded-md border border-emerald-200 transition" title="Kembalikan">
                                        Kembalikan
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center">
                            <i data-lucide="inbox" class="w-12 h-12 mx-auto text-gray-300 mb-3"></i>
                            <p class="text-gray-500">Belum ada riwayat transaksi sirkulasi.</p>
                            <a href="/transactions/scan" class="text-emerald-600 font-medium text-sm hover:underline mt-1 inline-block">Mulai Peminjaman</a>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
