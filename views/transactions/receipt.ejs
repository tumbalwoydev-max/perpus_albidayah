<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Struk Sirkulasi TRX-<%= transaction.id %></title>
    <style>
        /* Base Styling */
        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            color: #000;
            background: #fff;
            margin: 0;
            padding: 10px;
            display: flex;
            justify-content: center;
        }

        /* 58mm Thermal Printer Width = 58mm paper, 48mm printable area ~ 180px */
        .receipt-container {
            width: 48mm; 
            max-width: 250px;
            padding: 5px;
        }

        h3, p { margin: 0; padding: 0; }
        
        .text-center { text-align: center; }
        .text-left { text-align: left; }
        .text-right { text-align: right; }
        .font-bold { font-weight: bold; }
        .text-sm { font-size: 10px; }
        .mb-1 { margin-bottom: 5px; }
        .mb-2 { margin-bottom: 10px; }
        .mb-3 { margin-bottom: 15px; }

        .line { border-bottom: 1px dashed #000; margin: 10px 0; }

        .row { display: flex; justify-content: space-between; margin-bottom: 5px; }
        .row span.label { flex: 0 0 50%; text-align: left; }
        .row span.value { flex: 1; text-align: right; font-weight: bold; word-break: break-word; }

        /* Print Media Query */
        @media print {
            body { 
                background: none; 
                margin: 0; 
                padding: 0; 
            }
            .no-print { display: none !important; }
            .receipt-container { width: 100%; border: none; padding: 0; }
        }

        /* Print Button */
        .btn-print {
            display: block;
            width: 100%;
            padding: 8px;
            background-color: #047857;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            margin-bottom: 15px;
            font-family: inherit;
        }
        .btn-back {
            display: block;
            width: 100%;
            padding: 8px;
            background-color: #e5e7eb;
            color: #374151;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            box-sizing: border-box;
            font-family: inherit;
        }
    </style>
</head>
<body>

    <div class="receipt-container">
        
        <div class="no-print">
            <button class="btn-print" id="btn-print-bluetooth" style="background-color: #0284c7; margin-bottom: 8px;">Cetak Otomatis (Bluetooth)</button>
            <button class="btn-print" onclick="window.print()">Cetak Standard (Browser Dialog)</button>
            <a href="/transactions" class="btn-back mb-3">Kembali ke Dashboard</a>
        </div>

        <div class="text-center mb-2">
            <img src="/images/logo.png" alt="Logo" style="width: 65px; height: auto; margin-bottom: 5px;">
            <h3 class="mb-1"><%= school_name %></h3>
            <p class="text-sm border-bottom">SISTEM PERPUSTAKAAN</p>
        </div>

        <div class="line"></div>

        <div class="text-center mb-2 font-bold text-sm">
            <%= transaction.return_date ? 'BUKTI PENGEMBALIAN' : 'BUKTI PEMINJAMAN' %>
        </div>

        <div class="row text-sm">
            <span class="label">No Resi:</span>
            <span class="value">TRX-<%= transaction.id %></span>
        </div>
        <div class="row text-sm">
            <span class="label">Siswa:</span>
            <span class="value"><%= transaction.Student.name %></span>
        </div>
        <div class="row text-sm">
            <span class="label">NISN:</span>
            <span class="value"><%= transaction.Student.nisn %></span>
        </div>

        <div class="line"></div>

        <p class="font-bold text-center text-sm mb-1">DATA BUKU</p>
        <p class="text-sm mb-2 text-center" style="word-break: break-word;"><%= transaction.Book.title %></p>

        <div class="row text-sm">
            <span class="label">Tgl Pinjam:</span>
            <span class="value"><%= transaction.borrow_date %></span>
        </div>
        <div class="row text-sm">
            <span class="label">Batas Kembali:</span>
            <span class="value"><%= transaction.expected_return_date %></span>
        </div>

        <% if(transaction.return_date) { %>
            <div class="row text-sm">
                <span class="label">Dikembalikan:</span>
                <span class="value"><%= transaction.return_date %></span>
            </div>
            <% if(transaction.fine > 0) { %>
                <div class="line"></div>
                <div class="row text-sm">
                    <span class="label font-bold">DENDA:</span>
                    <span class="value">Rp<%= transaction.fine %></span>
                </div>
            <% } %>
        <% } %>

        <div class="line"></div>

        <div class="text-center text-sm mb-3">
            <p class="mb-1">Terima Kasih!</p>
            <p>Harap kembalikan buku tepat waktu agar terhindar dari denda membengkak.</p>
        </div>
        
        <div class="text-center text-sm" style="margin-top:20px;">
            <p>..................</p>
            <p>Petugas Perpustakaan</p>
        </div>

    </div>

    <!-- Script Printer Bluetooth API -->
    <script src="/js/printer.js"></script>

    <!-- Print Logic -->
    <script>
        const btnBluetooth = document.getElementById('btn-print-bluetooth');

        // Pengecekan status bluetooth device dan trigger
        const doBluetoothPrint = async () => {
            try {
                btnBluetooth.disabled = true;
                btnBluetooth.innerHTML = "Menghubungkan...";
                
                // Cari koneksi yang ada atau coba auto-reconnect
                if (!window.escposPrinter.isConnected) {
                    const reconnected = await window.escposPrinter.autoConnect();
                    if (!reconnected) {
                        // Jika autoConnect gagal, pancing dengan dialog manual
                        const success = await window.escposPrinter.connect();
                        if (!success) {
                            btnBluetooth.disabled = false;
                            btnBluetooth.innerHTML = "Cetak Otomatis (Bluetooth)";
                            return;
                        }
                    }
                }

                btnBluetooth.innerHTML = "Sedang Mencetak...";
                
                await window.escposPrinter.printReceipt({
                    school_name: "<%= school_name %>",
                    logo_url: "/images/logo.png", // Tambahan logo
                    is_return: <%= !!transaction.return_date %>,
                    transaction_id: "<%= transaction.id %>",
                    student_name: "<%= transaction.Student.name %>",
                    student_nisn: "<%= transaction.Student.nisn %>",
                    book_title: "<%= transaction.Book.title %>",
                    borrow_date: "<%= transaction.borrow_date %>",
                    expected_return_date: "<%= transaction.expected_return_date %>",
                    return_date: "<%= transaction.return_date || '' %>",
                    fine: <%= transaction.fine || 0 %>
                });

                btnBluetooth.innerHTML = "Cetak Selesai!";
                btnBluetooth.style.backgroundColor = "#059669";
                
                setTimeout(() => {
                    btnBluetooth.disabled = false;
                    btnBluetooth.innerHTML = "Cetak Otomatis (Bluetooth)";
                    btnBluetooth.style.backgroundColor = "#0284c7";
                }, 3000);

            } catch (error) {
                console.error('Bluetooth Print Error:', error);
                alert("Gagal mencetak: " + error.message);
                btnBluetooth.disabled = false;
                btnBluetooth.innerHTML = "Cetak Otomatis (Bluetooth)";
            }
        };

        btnBluetooth.addEventListener('click', doBluetoothPrint);

        // Auto print attempt
        window.addEventListener('load', async () => { 
            const savedName = localStorage.getItem('bluetooth_printer_name');
            if (savedName) {
                // Tampilkan info sedang mencoba menyambung
                btnBluetooth.innerHTML = "Menyambung ke " + savedName + "...";
                
                // Coba autoConnect (tanpa dialog)
                const success = await window.escposPrinter.autoConnect();
                if (success) {
                    doBluetoothPrint(); 
                } else {
                    btnBluetooth.innerHTML = "Klik untuk Cetak & Hubungkan";
                    btnBluetooth.style.backgroundColor = "#fbbf24"; // Amber
                    btnBluetooth.style.color = "#000";
                }
            } else {
                // Fallback jika tidak ada printer terdaftar
                btnBluetooth.innerHTML = "Hubungkan Printer di Pengaturan";
                btnBluetooth.style.opacity = "0.5";
            }
        });
    </script>
</body>
</html>
