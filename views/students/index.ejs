<%- include('../partials/header') %>

<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">Data Master Siswa</h1>
        <p class="text-sm text-gray-500 mt-1">Kelola data seluruh siswa beserta QR Code kepemilikan.</p>
    </div>
    <a href="/admin/students/create" class="inline-flex items-center justify-center py-2.5 px-4 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 focus:ring-2 focus:ring-emerald-500 transition gap-2">
        <i data-lucide="plus" class="w-4 h-4"></i> Tambah Siswa
    </a>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">No</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Foto</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">QR Code</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">NISN</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nama Lengkap</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kelas</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Aksi</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                <% if(students.length > 0) { %>
                    <% students.forEach((student, index) => { %>
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= index + 1 %></td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <% if(student.photo_path) { %>
                                    <div class="w-10 h-10 rounded-full overflow-hidden border border-gray-200 shadow-sm">
                                        <img src="<%= student.photo_path %>" alt="Photo" class="w-full h-full object-cover">
                                    </div>
                                <% } else { %>
                                    <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-400">
                                        <i data-lucide="user" class="w-5 h-5"></i>
                                    </div>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <% if(student.qr_code_path) { %>
                                    <div class="w-12 h-12 bg-white border border-gray-200 rounded p-1">
                                        <img src="<%= student.qr_code_path %>" alt="QR <%= student.nisn %>" class="w-full h-full object-contain">
                                    </div>
                                <% } else { %>
                                    <span class="text-xs text-gray-400">N/A</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-emerald-600"><%= student.nisn %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium"><%= student.name %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <span class="px-2.5 py-0.5 rounded-full bg-blue-50 text-blue-700 border border-blue-200 text-xs font-medium">
                                    <%= student.class %>
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium flex justify-end gap-2">
                                <a href="<%= student.qr_code_path %>" target="_blank" download="QR_<%= student.nisn %>.png" class="text-blue-600 hover:text-blue-900 bg-blue-50 p-1.5 rounded-md transition" title="Download QR">
                                    <i data-lucide="download" class="w-4 h-4"></i>
                                </a>
                                <a href="/admin/students/edit/<%= student.id %>" class="text-amber-600 hover:text-amber-900 bg-amber-50 p-1.5 rounded-md transition" title="Edit">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <form action="/admin/students/delete/<%= student.id %>" method="POST" class="inline" onsubmit="return confirm('Apakah Anda yakin ingin menghapus data siswa ini? Semua transaksi terkait mungkin akan terpengaruh.')">
                                    <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 p-1.5 rounded-md transition" title="Hapus">
                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center">
                            <i data-lucide="users" class="w-12 h-12 mx-auto text-gray-300 mb-3"></i>
                            <p class="text-gray-500">Belum ada data siswa.</p>
                            <a href="/admin/students/create" class="text-emerald-600 font-medium text-sm hover:underline mt-1 inline-block">Mulai tambahkan data</a>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
