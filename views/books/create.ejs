<%- include('../partials/header') %>

<div class="mb-6">
    <a href="/admin/books" class="inline-flex items-center text-sm font-medium text-emerald-600 hover:text-emerald-700 transition mb-4 gap-1">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Kembali ke Data Buku
    </a>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">Tambah Data Buku</h1>
    <p class="text-sm text-gray-500 mt-1">Isi detail form di bawah ini untuk menambah inventaris perpustakaan baru.</p>
</div>

<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 max-w-2xl">
    <% if(typeof error !== 'undefined' && error) { %>
        <div class="mb-6 bg-red-50 border border-red-200 text-red-600 rounded-lg p-4 flex gap-3 text-sm">
            <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i> <span><%= error %></span>
        </div>
    <% } %>

    <form action="/admin/books/create" method="POST" class="space-y-6" enctype="multipart/form-data">
        
        <div>
            <label for="cover" class="block text-sm font-medium text-gray-700 mb-1">Cover Buku (Opsional)</label>
            <input type="file" name="cover" id="cover" accept="image/*"
                class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100 border border-gray-300 rounded-lg">
        </div>

        <div>
            <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Judul Buku</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i data-lucide="type" class="w-5 h-5 text-gray-400"></i>
                </div>
                <input type="text" name="title" id="title" required
                    class="pl-10 block w-full border-gray-300 rounded-lg shadow-sm focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm py-2 px-3 border" 
                    placeholder="Contoh: Matematika Kelas 4 Kurikulum Merdeka">
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label for="author" class="block text-sm font-medium text-gray-700 mb-1">Penulis / Penerbit</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="pen-tool" class="w-5 h-5 text-gray-400"></i>
                    </div>
                    <input type="text" name="author" id="author" required
                        class="pl-10 block w-full border-gray-300 rounded-lg shadow-sm focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm py-2 px-3 border"
                        placeholder="Contoh: Kemdikbud">
                </div>
            </div>

            <div>
                <label for="stock" class="block text-sm font-medium text-gray-700 mb-1">Stok Inventaris</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="layers" class="w-5 h-5 text-gray-400"></i>
                    </div>
                    <input type="number" min="0" name="stock" id="stock" required
                        class="pl-10 block w-full border-gray-300 rounded-lg shadow-sm focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm py-2 px-3 border"
                        placeholder="10">
                </div>
            </div>
        </div>

        <div class="pt-4 border-t border-gray-100 flex justify-end">
            <button type="submit" class="inline-flex justify-center items-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-colors gap-2">
                <i data-lucide="save" class="w-4 h-4"></i> Simpan Buku
            </button>
        </div>

    </form>
</div>

<%- include('../partials/footer') %>
