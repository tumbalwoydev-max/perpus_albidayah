<%- include('../partials/header') %>

<div class="mb-6">
    <a href="/transactions" class="inline-flex items-center text-sm font-medium text-emerald-600 hover:text-emerald-700 transition mb-4 gap-1">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Kembali ke Riwayat Sirkulasi
    </a>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">Proses Pengembalian Buku</h1>
    <p class="text-sm text-gray-500 mt-1">Konfirmasi pengembalian buku dan cek nominal denda otomatis.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
    <!-- Info Peminjaman -->
    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 shadow-sm">
        <h3 class="font-bold text-gray-900 border-b border-gray-200 pb-3 mb-4 flex gap-2">
            <i data-lucide="info" class="w-5 h-5 text-gray-400"></i> Detail Peminjaman (TRX-<%= transaction.id %>)
        </h3>
        
        <div class="space-y-4 text-sm">
            <div class="flex justify-between">
                <span class="text-gray-500">Judul Buku:</span>
                <span class="font-medium text-gray-900 text-right"><%= transaction.Book.title %></span>
            </div>
            <div class="flex justify-between">
                <span class="text-gray-500">Peminjam:</span>
                <span class="font-medium text-gray-900 text-right"><%= transaction.Student.name %> <br><span class="text-xs text-gray-400"><%= transaction.Student.nisn %></span></span>
            </div>
            <div class="flex justify-between">
                <span class="text-gray-500">Tanggal Pinjam:</span>
                <span class="font-medium text-gray-900"><%= transaction.borrow_date %></span>
            </div>
            <div class="flex justify-between">
                <span class="text-gray-500">Batas Waktu:</span>
                <span class="font-medium text-emerald-600"><%= transaction.expected_return_date %></span>
            </div>
        </div>
    </div>

    <!-- Form Pengembalian & Denda -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <form action="/transactions/return/<%= transaction.id %>" method="POST" class="space-y-6">
            
            <div>
                <label for="return_date" class="block text-sm font-medium text-gray-700 mb-1">Tanggal Dikembalikan</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="calendar-check" class="w-5 h-5 text-gray-400"></i>
                    </div>
                    <input type="date" name="return_date" id="return_date" value="<%= today %>" required readonly
                        class="pl-10 block w-full border-gray-300 rounded-lg shadow-sm focus:ring-emerald-500 focus:border-emerald-500 sm:text-sm py-2 px-3 border bg-gray-50">
                </div>
            </div>

            <% if(daysLate > 0) { %>
                <div class="bg-red-50 border border-red-200 rounded-xl p-4">
                    <div class="flex items-start gap-3">
                        <i data-lucide="alert-triangle" class="w-6 h-6 text-red-500 mt-1"></i>
                        <div class="w-full">
                            <h4 class="font-bold text-red-800 text-lg mb-1">Terlambat <%= daysLate %> Hari!</h4>
                            <p class="text-xs text-red-600 mb-3">Siswa melewati batas waktu pengembalian buku.</p>
                            
                            <label for="fine" class="block text-sm font-medium text-red-800 mb-1">Nominal Denda (Rp)</label>
                            <input type="number" name="fine" id="fine" value="<%= fine %>" required readonly
                                class="block w-full border-red-300 rounded-lg shadow-sm text-red-700 font-bold focus:ring-red-500 focus:border-red-500 text-lg bg-red-100 py-2 px-3 border border-red-200">
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 flex gap-3 items-center">
                    <div class="bg-white rounded-full p-2 flex-shrink-0">
                        <i data-lucide="check-circle-2" class="w-6 h-6 text-emerald-500"></i>
                    </div>
                    <div class="w-full">
                        <h4 class="font-bold text-emerald-800 mb-0">Tepat Waktu!</h4>
                        <p class="text-xs text-emerald-600 mb-0">Tidak ada denda karena pengembalian belum melewati batas pinjam.</p>
                        <input type="hidden" name="fine" value="0">
                    </div>
                </div>
            <% } %>

            <div class="pt-4 border-t border-gray-100 flex justify-end gap-3">
                <button type="submit" class="inline-flex justify-center items-center py-3 px-6 w-full border border-transparent shadow-sm font-medium rounded-xl text-white bg-emerald-600 hover:bg-emerald-700 transition-colors gap-2 text-base">
                    <i data-lucide="package-check" class="w-5 h-5"></i> Selesaikan Pengembalian
                </button>
            </div>

        </form>
    </div>
</div>

<%- include('../partials/footer') %>
